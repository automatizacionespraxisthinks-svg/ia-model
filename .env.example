# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=praxis-ia-model
APP_ENV=production
DEBUG=false
SECRET_KEY=change-this-to-a-random-64-char-secret

# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/praxis.db

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# ─── Modelos disponibles (separados por coma) ─────────────────────────────────
AVAILABLE_MODELS=mistral,llama3,phi3
DEFAULT_MODEL=mistral

# ─── Umbrales del router automático (en caracteres) ──────────────────────────
ROUTER_LIGHT_THRESHOLD=500
ROUTER_MEDIUM_THRESHOLD=2000
ROUTER_LIGHT_MODEL=phi3
ROUTER_MEDIUM_MODEL=mistral
ROUTER_HEAVY_MODEL=llama3

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Admin ────────────────────────────────────────────────────────────────────
# Clave admin inicial — cámbiala y guárdala en lugar seguro
ADMIN_SECRET=change-this-admin-secret
